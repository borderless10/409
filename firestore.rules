rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isOwner(ownerId) {
      return isAuthenticated() && request.auth.uid == ownerId;
    }

    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    match /stations/{stationId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin() || isOwner(resource.data.owner_id);
    }

    match /chargers/{chargerId} {
      allow read: if true;

      // Admin pode criar/atualizar/apagar livremente
      allow create, update, delete: if isAdmin();

      // Usuário autenticado pode apenas mudar status e current_session_id.
      // Nenhum outro campo do carregador pode ser alterado por ele.
      allow update: if isAuthenticated()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'current_session_id'])
        && request.resource.data.status in ['available', 'occupied', 'maintenance', 'reserved'];
    }

    match /bookings/{bookingId} {
      // Read: qualquer usuário autenticado pode ler (necessário para verificar conflitos ao reservar por charger_id).
      // Write: apenas o dono da reserva ou admin.
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isAuthenticated() && (resource.data.user_id == request.auth.uid || isAdmin());
    }

    match /chargingSessions/{sessionId} {
      allow read: if isAuthenticated() && (resource.data.user_id == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isAuthenticated() && (resource.data.user_id == request.auth.uid || isAdmin());
    }

    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (resource.data.user_id == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
